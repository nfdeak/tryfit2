# ============================================================================
# Diet App — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` (root) and to `server/.env` for local development.
# On Vercel, set these in the project's Environment Variables settings.
# ============================================================================

# --- Database (Neon PostgreSQL) ---------------------------------------------
# Pooled connection — used by the runtime via the Neon serverless adapter.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct (non-pooled) connection — used by Prisma Migrate only.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Auth -------------------------------------------------------------------
# Long random string. Generate one with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# --- Runtime ----------------------------------------------------------------
NODE_ENV="development"
PORT="3001"

# --- Frontend URL (used for CORS allowlist + Google OAuth callback) ---------
# Local dev:
CLIENT_URL="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"
# Production example:
# CLIENT_URL="https://your-app.vercel.app"
# FRONTEND_URL="https://your-app.vercel.app"

# --- Anthropic / Claude API -------------------------------------------------
ANTHROPIC_API_KEY=""
# Optional override (defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL="claude-sonnet-4-20250514"

# --- Google OAuth (optional) ------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5173/api/auth/google/callback"

# --- Client (Vite) ----------------------------------------------------------
# Leave empty when API and frontend share the same origin (default on Vercel).
# Set this if you want the client to talk to a different API host.
VITE_API_URL=""
